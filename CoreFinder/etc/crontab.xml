<?xml version="1.0"?>
<!--
  Module : VP_CoreFinder
  Fichier : etc/crontab.xml
  Rôle : Définition des tâches planifiées (cron) pour réindexation, IA ou nettoyage
  Auteur : Auzoult Marc-Antoine
  Date : 2025-06-01
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="vp_corefinder_cron_reindex" instance="VP\CoreFinder\Cron\Reindex" method="execute">
            <schedule>0 * * * *</schedule> <!-- chaque heure -->
        </job>
        <job name="vp_corefinder_cron_ai_train" instance="VP\CoreFinder\Cron\TrainAI" method="execute">
            <schedule>0 2 * * *</schedule> <!-- tous les jours à 2h -->
        </job>
    </group>
</config>
