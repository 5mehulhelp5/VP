<?xml version="1.0"?>
<!--
  Module : VP_CoreFinder
  Fichier : view/frontend/layout/catalog_category_view.xml
  Rôle : Injection automatique du bloc de facettes sur les pages catégories
  Auteur : Auzoult Marc-Antoine
  Date : 2025-06-01
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="3columns"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <referenceContainer name="sidebar.additional">
            <block class="VP\CoreFinder\Block\FacetList"
                   name="vp.corefinder.facet.list"
                   template="VP_CoreFinder::facets.phtml"
                   before="catalog.leftnav"/>
        </referenceContainer>
    </body>
</page>
